# ---- Backend environment variables ----
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Public anon key (safe for clients, used for RLS-scoped requests).
SUPABASE_ANON_KEY=

# Service-role key — FULL database access. Server-side ONLY. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used to verify Supabase-issued access tokens (python-jose).
# Found in Supabase dashboard: Settings > API > JWT Secret.
SUPABASE_JWT_SECRET=

# Default timezone for scheduling (IANA name, e.g. America/Toronto).
TIMEZONE=America/Toronto

# Admin bootstrap credentials — read ONLY by scripts/seed_admin.py to create the
# single admin account. Never hardcoded, never committed (PROJECT_SPEC §2).
ADMIN_EMAIL=
ADMIN_PASSWORD=
